<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="debug" monitorInterval="120">
    <properties>
        <Property name="LOG_HOME">logs
        </Property>
    </properties>

    <Appenders>
        <Console name="Console" target="SYSTEM_OUT" immediateFlush="true">
            <ThresholdFilter level="debug" onMatch="ACCEPT" onMismatch="DENY" />
            <PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss..SSS} %-5level [%t] %c->%M -- %msg%xEx%n"/>
        </Console>

        <File name="FileLog" fileName="${LOG_HOME}//scanserver.${date:yyyy-MM-dd}.log" immediateFlush="true" append="false">
            <PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss..SSS} %-5level [%t] %c->%M -- %msg%xEx%n"/>
        </File>
    </Appenders>

    <Loggers>
        <root level="debug">
            <appender-ref ref="Console" />
            <appender-ref ref="FileLog" />
        </root>

        <Logger name="io.github.evoschema" level="debug"/>
        <Logger name="org.springframework" level="warn"/>
    </Loggers>
</Configuration>
